<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shyam | Full Stack Developer</title>
    <style>
        :root {
            --bg: #0f172a;
            --card: #1e293b;
            --text: #f8fafc;
            --accent: #38bdf8;
        }

        body {
            background-color: var(--bg);
            color: var(--text);
            font-family: 'Inter', sans-serif;
            margin: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 50px 20px;
        }

        header {
            text-align: center;
            margin-bottom: 50px;
        }

        h1 { font-size: 3rem; margin-bottom: 10px; }
        span { color: var(--accent); }

        .container {
            max-width: 900px;
            width: 100%;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
        }

        .project-card {
            background: var(--card);
            padding: 25px;
            border-radius: 15px;
            border: 1px solid #334155;
            transition: transform 0.3s ease;
        }

        .project-card:hover {
            transform: translateY(-10px);
            border-color: var(--accent);
        }

        .tech-badge {
            background: #0ea5e933;
            color: var(--accent);
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
            margin-right: 5px;
            display: inline-block;
            margin-top: 10px;
        }

        a {
            color: var(--accent);
            text-decoration: none;
            font-weight: bold;
            display: inline-block;
            margin-top: 15px;
        }
    </style>
</head>
<nav style="width: 100%; display: flex; justify-content: center; gap: 20px; margin-bottom: 30px;">
    <a href="/" style="background: #1e293b; padding: 10px 20px; border-radius: 5px;">Portfolio</a>
    <a href="/admin" style="background: #1e293b; padding: 10px 20px; border-radius: 5px;">Admin Panel</a>
</nav>
<body>

    <header>
        <h1>Shyam <span>Reddy</span></h1>
        <p>Full Stack Web Developer | Node.js & MongoDB Specialist</p>
    </header>

    <div class="container">
        <% projects.forEach(project => { %>
            <div class="project-card">
                <h3><%= project.title %></h3>
                <p><%= project.description %></p>
                <div>
                    <% project.techStack.forEach(tech => { %>
                        <span class="tech-badge"><%= tech %></span>
                    <% }) %>
                </div>
                <a href="<%= project.link %>" target="_blank">View Project →</a>
                <form action="/admin/delete/<%= project._id %>" method="POST" style="margin-top: 15px;">
    <button type="submit" style="background: #ef4444; color: white; border: none; padding: 5px 10px; border-radius: 5px; cursor: pointer; font-size: 0.8rem;" onclick="return confirm('Are you sure you want to delete this?')">
        Delete Project
    </button>
</form>
            </div>
        <% }) %>
    </div>
<section style="margin-top: 50px; background: #1e293b; padding: 40px; border-radius: 15px; width: 100%; max-width: 600px;">
    <h2 style="text-align: center;">Get In Touch</h2>
    <form action="/contact" method="POST" style="display: flex; flex-direction: column; gap: 15px;">
        <input type="text" name="name" placeholder="Your Name" required style="padding: 10px; border-radius: 5px; border: none;">
        <input type="email" name="email" placeholder="Your Email" required style="padding: 10px; border-radius: 5px; border: none;">
        <textarea name="message" placeholder="Your Message" rows="5" required style="padding: 10px; border-radius: 5px; border: none;"></textarea>
        <button type="submit" style="background: var(--accent); color: #0f172a; padding: 12px; border: none; border-radius: 5px; font-weight: bold; cursor: pointer;">Send Message</button>
    </form>
</section>
</body>
</html>